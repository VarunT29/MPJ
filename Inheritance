import java.util.*;

class Worker {
    double pay;

    void showPay() {
        System.out.println("Salary: " + pay);
    }
}

class PermanentEmployee extends Worker {

    void processSalary(Scanner sc) {
        System.out.println("Permanent Employee");
        System.out.print("Enter basic salary: ");
        pay = sc.nextDouble();

        System.out.print("Before increment: ");
        showPay();

        pay = pay * 1.50;

        System.out.print("After 50% increment: ");
        showPay();
        System.out.println();
    }
}

class Trainee extends Worker {

    void processSalary(Scanner sc) {
        System.out.println("Trainee");
        System.out.print("Enter basic salary: ");
        pay = sc.nextDouble();

        System.out.print("Before increment: ");
        showPay();

        pay = pay * 1.25;

        System.out.print("After 25% increment: ");
        showPay();
        System.out.println();
    }
}

public class CompanyTest {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter number of Permanent Employees: ");
        int pCount = sc.nextInt();

        for (int i = 0; i < pCount; i++) {
            PermanentEmployee p = new PermanentEmployee();
            p.processSalary(sc);
        }

        System.out.print("Enter number of Trainees: ");
        int tCount = sc.nextInt();

        for (int i = 0; i < tCount; i++) {
            Trainee t = new Trainee();
            t.processSalary(sc);
        }

        sc.close();
    }
}
